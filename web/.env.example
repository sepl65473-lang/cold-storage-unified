# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to version control.

# Set to true for local development with mock data (no backend needed)
# Set to false to connect to the real backend
VITE_USE_MOCK=true

# Your backend REST API base URL (no trailing slash)
VITE_API_BASE_URL=https://your-backend.example.com/api/v1

# Your backend WebSocket URL (leave empty if not yet implemented)
VITE_WS_URL=

# Mock mode login credentials (only used when VITE_USE_MOCK=true)
VITE_MOCK_EMAIL=your-email@example.com
VITE_MOCK_PASSWORD=your-password
